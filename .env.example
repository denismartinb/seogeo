# Copia este archivo como .env y rellena los valores
# NUNCA subas .env a GitHub — ya está en .gitignore

# Tu API key de Google AI Studio (gratuita en aistudio.google.com)
GEMINI_API_KEY=tu_gemini_api_key_aqui

# Entorno: dev (bypasea auth) | prod (requiere auth)
ENVIRONMENT=dev

# Tus propias API keys para clientes directos (separadas por comas)
# Genera strings random en: https://generate-secret.vercel.app/32
API_KEYS=clave_test_1234,clave_otro_cliente_5678

# Secret que RapidAPI usa para verificar que las llamadas vienen de su proxy
# Lo encuentras en RapidAPI Dashboard → tu API → Security
RAPIDAPI_PROXY_SECRET=
