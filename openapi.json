    "/analyze/seo": {
      "post": {
        "tags": [
          "SEO"
        ],
        "summary": "Análisis SEO completo",
        "description": "Genera metadata SEO completa a partir de un texto o contenido.\n\nAcepta parámetros como **query params** (`?text=...&target_keyword=...`) o como **JSON body**.\n\n**Devuelve:**\n- Title tag y meta description optimizados\n- Slug limpio\n- Keywords principal y secundarias (LSI)\n- Schema.org (Article, FAQ si aplica)\n- Open Graph tags\n- Puntuación SEO 0-100\n- Problemas detectados y sugerencias de mejora",
        "operationId": "analyze_seo_analyze_seo_post",
        "security": [
          {
            "APIKeyHeader": []
          }
        ],
        "parameters": [
          {
            "name": "text",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "nullable": true,
              "description": "Texto o contenido a analizar (mín. 10 chars)",
              "title": "Text"
            },
            "description": "Texto o contenido a analizar (mín. 10 chars)"
          },
          {
            "name": "url",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "nullable": true,
              "description": "URL de origen (opcional, mejora el contexto)",
              "title": "Url"
            },
            "description": "URL de origen (opcional, mejora el contexto)"
          },
          {
            "name": "language",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "nullable": true,
              "description": "Idioma objetivo: es, en, fr, de, pt...",
              "title": "Language"
            },
            "description": "Idioma objetivo: es, en, fr, de, pt..."
          },
          {
            "name": "target_keyword",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "nullable": true,
              "description": "Keyword principal a optimizar",
              "title": "Target Keyword"
            },
            "description": "Keyword principal a optimizar"
